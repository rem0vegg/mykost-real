# Copy this file to .env and fill in the values before running docker-compose.
# .env is gitignored and must never be committed.

POSTGRES_USER=mykost_user
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=mykost_db

# Must be a long, random string (e.g. openssl rand -hex 32)
JWT_SECRET=c591f61ecce283c8616f9c9612eeb1ad59fde125b1875cc454e310d9c32e3d30

# Frontend API URL (used by the frontend container)
VITE_API_URL=http://localhost:5000
