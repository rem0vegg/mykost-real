# Copy this file to .env and fill in the values before running docker-compose.
# .env is gitignored and must never be committed.

POSTGRES_USER=mykost_user
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=mykost_db

# Must be a long, random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string

# Frontend API URL (used by the frontend container)
VITE_API_URL=http://localhost:5000

# Midtrans Payment Gateway
# Daftar di https://dashboard.sandbox.midtrans.com untuk sandbox keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Set ke 'production' saat live; biarkan kosong / 'sandbox' untuk development
MIDTRANS_ENV=sandbox

# Frontend — Midtrans client key & env (harus diawali VITE_ agar terbaca Vite)
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
VITE_MIDTRANS_ENV=sandbox
